# Database Connection
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@localhost:5432/trading_db

# --- GOOGLE GEMINI CONFIG ---
# Get Key: https://aistudio.google.com/app/apikey
# Multiple keys separated by comma for rotation
RESEARCH_KEYS=key1,key2,key3
BACKTEST_KEYS=key1,key2,key3

MODEL_FAST=gemma-3-27b-it
MODEL_SMART=gemma-3-27b-it

# SearXNG URL (Default Localhost)
SEARXNG_BASE_URL=http://localhost:8081/

# Coinbase API (Optional - For Paper Trading/Live)
COINBASE_API_KEY=your_key_name
COINBASE_API_SECRET=your_secret_key

# --- PORTS & HOSTS ---
# Customize these if you have port conflicts
DB_HOST=localhost
DB_PORT=5432
SEARXNG_PORT=8081
DASHBOARD_PORT=3000
ADMINER_PORT=8080
