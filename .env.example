# ============================================
# Autonomous Trading Laboratory Configuration
# ============================================
# Copy this file to .env and fill in your values
# See docs/GOOGLE_API_KEYS.md for detailed API key setup

# --- DATABASE ---
DATABASE_URL=postgresql+asyncpg://myuser:mypassword@localhost:5432/trading_db

# --- GOOGLE GEMINI API KEYS ---
# Get keys at: https://aistudio.google.com/app/apikey
#
# IMPORTANT: Use multiple keys for rate limit handling!
# Free tier: 15 RPM per key, 1500 requests/day per key
#
# Format: Comma-separated, no spaces
# Example: RESEARCH_KEYS=AIzaSyA...,AIzaSyB...,AIzaSyC...
#
# For best results, create keys in DIFFERENT Google Cloud projects
# to get completely separate rate limit quotas.

# Keys for Research Agents (Scout + Sniper)
RESEARCH_KEYS=your_gemini_key_1,your_gemini_key_2,your_gemini_key_3

# Keys for Backtest Agents (Coder + Validator)
# Can be same as RESEARCH_KEYS or separate for isolated quotas
BACKTEST_KEYS=your_gemini_key_4,your_gemini_key_5,your_gemini_key_6

# --- MODEL SELECTION ---
# MODEL_FAST: High-quota model for Scout (fast searches)
# MODEL_SMART: Better reasoning model for Sniper/Coder (complex analysis)
#
# Recommended free tier models:
#   - gemini-2.5-flash-lite (fast, high quota)
#   - gemini-2.5-flash (balanced)
#   - gemini-2.5-pro (best quality, lower quota)
MODEL_FAST=gemini-2.5-flash-lite
MODEL_SMART=gemini-2.5-flash

# --- SEARXNG (Web Search Engine) ---
# Local SearXNG instance for web searches
# Start with: docker-compose up -d searxng
SEARXNG_BASE_URL=http://localhost:8081/

# --- COINBASE API (Optional - For Paper/Live Trading) ---
# Only needed if you want to execute trades
# Get keys at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_key_name
COINBASE_API_SECRET=your_secret_key

# --- PORTS & HOSTS ---
# Customize if you have port conflicts with other services
DB_HOST=localhost
DB_PORT=5432
SEARXNG_PORT=8081
DASHBOARD_PORT=3000
ADMINER_PORT=8080

# --- DEBUG MODE ---
# Set to 'true' to enable verbose logging (writes to logs/*_debug.log)
# Useful for diagnosing JSON parse failures and API issues
DEBUG_MODE=false
